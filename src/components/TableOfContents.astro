---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

{
  tocHeadings.length > 0 && (
    <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-5">
      <p class="text-sm font-semibold uppercase tracking-wide text-white">On this page</p>
      <ul class="mt-4 space-y-2 text-sm">
        {tocHeadings.map((heading) => (
          <li class:list={[heading.depth === 3 && 'ml-3']}>
            <a
              href={`#${heading.slug}`}
              class="text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-accent)]"
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )
}
