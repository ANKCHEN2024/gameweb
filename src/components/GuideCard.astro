---
import type { GuideEntry } from '../utils/guides';
import type { GameSlug } from '../consts';
import { formatDate, getGameMeta, getGuideUrl } from '../utils/guides';
import GameImage from './GameImage.astro';

interface Props {
  guides: GuideEntry[];
  showGame?: boolean;
  variant?: 'grid' | 'list';
}

const { guides, showGame = true, variant = 'grid' } = Astro.props;
---

{
  variant === 'list' ? (
    <ol class="flex flex-col gap-3" data-guide-list>
      {guides.map((guide) => {
        const gameMeta = getGameMeta(guide.data.game);
        const gameSlug = guide.data.game as GameSlug;
        return (
          <li>
            <article
              class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] transition hover:border-[var(--color-accent)]/50"
              data-guide-card
              data-game={guide.data.game}
              data-tags={guide.data.tags.join(',')}
              data-title={guide.data.title.toLowerCase()}
            >
              <a
                href={getGuideUrl(guide)}
                class="flex items-center gap-4 p-4 sm:gap-6 sm:p-5"
              >
                <time
                  datetime={guide.data.publishedAt.toISOString()}
                  class="w-24 shrink-0 text-xs leading-snug text-[var(--color-text-muted)] sm:w-28 sm:text-sm"
                >
                  {formatDate(guide.data.publishedAt)}
                </time>
                <div class="min-w-0 flex-1">
                  {showGame && (
                    <p class="text-xs font-medium uppercase tracking-wide text-[var(--color-accent)]">
                      {gameMeta.title}
                    </p>
                  )}
                  <h2
                    class:list={[
                      'break-words text-base font-bold leading-snug text-white group-hover:text-[var(--color-accent)] sm:text-lg',
                      showGame && 'mt-0.5',
                    ]}
                  >
                    {guide.data.title}
                  </h2>
                  <p class="mt-1 line-clamp-1 text-sm text-[var(--color-text-muted)]">
                    {guide.data.description}
                  </p>
                </div>
                <GameImage
                  slug={gameSlug}
                  title={gameMeta.title}
                  variant="thumb"
                  class="hidden h-16 w-24 shrink-0 overflow-hidden rounded-lg sm:block"
                />
              </a>
            </article>
          </li>
        );
      })}
    </ol>
  ) : (
    <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3" data-guide-list>
  {
    guides.map((guide) => {
      const gameMeta = getGameMeta(guide.data.game);
      const gameSlug = guide.data.game as GameSlug;
      return (
        <article
          class="group flex h-full flex-col overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] transition hover:border-[var(--color-accent)]/50 hover:shadow-lg hover:shadow-black/20"
          data-guide-card
          data-game={guide.data.game}
          data-tags={guide.data.tags.join(',')}
          data-title={guide.data.title.toLowerCase()}
        >
          <a href={getGuideUrl(guide)} class="flex h-full flex-col">
            <GameImage slug={gameSlug} title={gameMeta.title} variant="card" />
            <div class="flex flex-1 flex-col p-5">
              {showGame && (
                <p class="text-xs font-medium uppercase tracking-wide text-[var(--color-accent)]">
                  {gameMeta.title}
                </p>
              )}
              <h2
                class:list={[
                  'break-words text-lg font-bold leading-snug text-white group-hover:text-[var(--color-accent)]',
                  showGame && 'mt-1',
                ]}
              >
                {guide.data.title}
              </h2>
              <p class="mt-2 line-clamp-3 break-words text-sm leading-relaxed text-[var(--color-text-muted)]">
                {guide.data.description}
              </p>
              {
                guide.data.tags.length > 0 && (
                  <ul class="mt-3 flex flex-wrap gap-2">
                    {guide.data.tags.slice(0, 3).map((tag) => (
                      <li class="rounded-full bg-[var(--color-surface-muted)] px-2.5 py-0.5 text-xs text-[var(--color-text-muted)]">
                        {tag}
                      </li>
                    ))}
                  </ul>
                )
              }
              <p class="mt-auto pt-4 text-xs text-[var(--color-text-muted)]">
                {formatDate(guide.data.publishedAt)}
              </p>
            </div>
          </a>
        </article>
      );
    })
  }
</div>
  )
}
