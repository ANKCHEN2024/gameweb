---
import type { GuideEntry } from '../utils/guides';
import type { GameSlug } from '../consts';
import { formatDate, getGameMeta, getGuideUrl } from '../utils/guides';
import { getGameAccentColor, getGameBannerUrl } from '../utils/images';

interface Props {
  guides: GuideEntry[];
  showGame?: boolean;
}

const { guides, showGame = true } = Astro.props;
---

<div class="guide-feed flex flex-col gap-5" data-guide-list>
  {
    guides.map((guide) => {
      const gameMeta = getGameMeta(guide.data.game);
      const gameSlug = guide.data.game as GameSlug;
      const bannerUrl = getGameBannerUrl(gameSlug);
      const accent = getGameAccentColor(gameSlug);

      return (
        <article
          class="guide-feed-item group"
          data-guide-card
          data-game={guide.data.game}
          data-tags={guide.data.tags.join(',')}
          data-title={guide.data.title.toLowerCase()}
        >
          <a
            href={getGuideUrl(guide)}
            class="block overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] transition hover:border-[var(--color-accent)]/40 hover:shadow-xl hover:shadow-black/25"
          >
            <div class="relative h-24 overflow-hidden sm:h-28">
              <img
                src={bannerUrl}
                alt=""
                class="h-full w-full object-cover object-center opacity-70 transition duration-500 group-hover:scale-105 group-hover:opacity-90"
                loading="lazy"
                decoding="async"
                width={460}
                height={215}
              />
              <div
                class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--color-surface-elevated)]/40 to-[var(--color-surface-elevated)]"
                aria-hidden="true"
              />
            </div>

            <div
              class="relative -mt-8 px-5 pb-5 sm:-mt-10 sm:px-6 sm:pb-6"
              style={`border-left: 3px solid ${accent}`}
            >
              <div class="pl-4">
                {showGame && (
                  <span
                    class="inline-block rounded-md px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wide"
                    style={`background: color-mix(in srgb, ${accent} 22%, transparent); color: ${accent}`}
                  >
                    {gameMeta.title}
                  </span>
                )}
                <h2
                  class:list={[
                    'break-words text-xl font-bold leading-snug text-white transition group-hover:text-[var(--color-accent)] sm:text-2xl',
                    showGame && 'mt-3',
                    !showGame && 'mt-0',
                  ]}
                >
                  {guide.data.title}
                </h2>
                <p class="mt-2 line-clamp-2 break-words text-sm leading-relaxed text-[var(--color-text-muted)] sm:text-base">
                  {guide.data.description}
                </p>

                <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2">
                  <time
                    class="text-xs text-[var(--color-text-muted)]"
                    datetime={guide.data.publishedAt.toISOString()}
                  >
                    {formatDate(guide.data.publishedAt)}
                  </time>
                  {
                    guide.data.tags.length > 0 && (
                      <ul class="flex flex-wrap gap-1.5">
                        {guide.data.tags.slice(0, 3).map((tag) => (
                          <li class="rounded bg-[var(--color-surface-muted)] px-2 py-0.5 text-xs text-[var(--color-text-muted)]">
                            {tag}
                          </li>
                        ))}
                      </ul>
                    )
                  }
                  <span class="ml-auto text-xs font-medium text-[var(--color-accent)] opacity-0 transition group-hover:opacity-100">
                    Read guide →
                  </span>
                </div>
              </div>
            </div>
          </a>
        </article>
      );
    })
  }
</div>
