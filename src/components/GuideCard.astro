---
import type { GuideEntry } from '../utils/guides';
import type { GameSlug } from '../consts';
import { formatDate, getGameMeta, getGuideUrl } from '../utils/guides';
import { getGameAccentColor } from '../utils/images';
import GuideThumb from './GuideThumb.astro';

interface Props {
  guides: GuideEntry[];
  showGame?: boolean;
}

const { guides, showGame = true } = Astro.props;
---

<div class="guide-catalog grid gap-3 sm:grid-cols-2 sm:gap-4" data-guide-list>
  {
    guides.map((guide) => {
      const gameMeta = getGameMeta(guide.data.game);
      const gameSlug = guide.data.game as GameSlug;
      const accent = getGameAccentColor(gameSlug);

      return (
        <article
          class="guide-catalog-item group min-w-0"
          data-guide-card
          data-game={guide.data.game}
          data-tags={guide.data.tags.join(',')}
          data-title={guide.data.title.toLowerCase()}
        >
          <a
            href={getGuideUrl(guide)}
            class="flex h-full min-w-0 gap-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-3 transition hover:border-[var(--color-accent)]/45 hover:bg-[var(--color-surface-muted)]/40 sm:gap-4 sm:p-4"
          >
            <GuideThumb slug={gameSlug} title={gameMeta.title} accent={accent} />

            <div class="flex min-w-0 flex-1 flex-col">
              {showGame && (
                <p
                  class="truncate text-[11px] font-semibold uppercase tracking-wide"
                  style={`color: ${accent}`}
                >
                  {gameMeta.title}
                </p>
              )}
              <h2
                class:list={[
                  'line-clamp-2 break-words text-sm font-bold leading-snug text-white group-hover:text-[var(--color-accent)] sm:text-base',
                  showGame && 'mt-0.5',
                ]}
              >
                {guide.data.title}
              </h2>
              <p class="mt-1 line-clamp-2 break-words text-xs leading-relaxed text-[var(--color-text-muted)] sm:text-sm">
                {guide.data.description}
              </p>

              <div class="mt-auto flex flex-wrap items-center gap-2 pt-2">
                <time
                  class="text-[11px] text-[var(--color-text-muted)]"
                  datetime={guide.data.publishedAt.toISOString()}
                >
                  {formatDate(guide.data.publishedAt)}
                </time>
                {
                  guide.data.tags.length > 0 && (
                    <span class="hidden text-[11px] text-[var(--color-text-muted)] sm:inline">
                      · {guide.data.tags.slice(0, 2).join(', ')}
                    </span>
                  )
                }
              </div>
            </div>

            <span
              class="hidden shrink-0 self-center text-lg text-[var(--color-text-muted)] transition group-hover:translate-x-0.5 group-hover:text-[var(--color-accent)] sm:inline"
              aria-hidden="true"
            >
              ›
            </span>
          </a>
        </article>
      );
    })
  }
</div>
