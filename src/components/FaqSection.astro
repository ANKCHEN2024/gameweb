---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<section class="mt-10">
  <h2 class="text-2xl font-bold text-white">Frequently asked questions</h2>
  <div class="mt-6 space-y-4">
    {
      items.map((item) => (
        <details class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-4">
          <summary class="cursor-pointer font-medium text-white">{item.question}</summary>
          <p class="mt-3 text-[var(--color-text-muted)]">{item.answer}</p>
        </details>
      ))
    }
  </div>
</section>
