---
interface Props {
  id?: string;
  placeholder?: string;
  action?: string;
}

const {
  id = 'site-search',
  placeholder = 'Search guides...',
  action = '/search/',
} = Astro.props;
---

<form action={action} method="get" class="relative w-full max-w-xs">
  <label for={id} class="sr-only">Search guides</label>
  <input
    id={id}
    type="search"
    name="q"
    placeholder={placeholder}
    class="w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-muted)] px-3 py-2 pr-9 text-sm text-white placeholder:text-[var(--color-text-muted)] focus:border-[var(--color-accent)] focus:outline-none"
  />
  <svg
    class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-[var(--color-text-muted)]"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
  </svg>
</form>
