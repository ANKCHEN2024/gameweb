---
import { SITE } from '../consts';
import SearchBar from './SearchBar.astro';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/games/', label: 'Games' },
  { href: '/guides/', label: 'Guides' },
  { href: '/about/', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-[var(--color-border)] bg-[var(--color-surface-elevated)]/80 backdrop-blur">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-4 py-4">
    <a href="/" class="flex items-center gap-2 font-bold text-white">
      <span
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-[var(--color-accent)] text-sm text-[var(--color-surface)]"
        aria-hidden="true"
      >
        SP
      </span>
      <span>{SITE.title}</span>
    </a>

    <div class="flex flex-1 flex-wrap items-center justify-end gap-4">
      <SearchBar id="header-search" />

      <nav aria-label="Main navigation">
        <ul class="flex flex-wrap items-center gap-1 sm:gap-2">
          {
            navLinks.map((link) => {
              const isActive =
                link.href === '/'
                  ? currentPath === '/'
                  : currentPath.startsWith(link.href);
              return (
                <li>
                  <a
                    href={link.href}
                    class:list={[
                      'rounded-lg px-3 py-2 text-sm transition-colors',
                      isActive
                        ? 'bg-[var(--color-surface-muted)] text-white'
                        : 'text-[var(--color-text-muted)] hover:text-white',
                    ]}
                    aria-current={isActive ? 'page' : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>
    </div>
  </div>
</header>
