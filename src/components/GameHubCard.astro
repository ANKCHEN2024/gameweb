---
import type { GameSlug } from '../consts';
import GameImage from './GameImage.astro';

interface Props {
  slug: GameSlug;
  title: string;
  description: string;
  guideCount: number;
  trending?: boolean;
  releaseDate?: string;
}

const { slug, title, description, guideCount, trending = false, releaseDate } =
  Astro.props;
---

<a
  href={`/games/${slug}/`}
  class="group block overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] transition hover:border-[var(--color-accent)]/50 hover:shadow-lg hover:shadow-black/20"
  data-game-card
  data-game-title={title.toLowerCase()}
>
  <GameImage slug={slug} title={title} variant="card" />
  <div class="p-5">
    <div class="flex items-start justify-between gap-3">
      <h3 class="text-xl font-bold text-white group-hover:text-[var(--color-accent)]">
        {title}
      </h3>
      {
        trending && (
          <span class="shrink-0 rounded-full bg-[var(--color-accent)]/15 px-2.5 py-0.5 text-xs font-medium text-[var(--color-accent)]">
            Trending
          </span>
        )
      }
    </div>
    <p class="mt-2 line-clamp-2 text-sm text-[var(--color-text-muted)]">{description}</p>
    <div class="mt-4 flex flex-wrap items-center gap-3 text-xs text-[var(--color-text-muted)]">
      <span class="font-medium text-[var(--color-accent)]">{guideCount} guides</span>
      {releaseDate && <span>Released {releaseDate}</span>}
    </div>
  </div>
</a>
