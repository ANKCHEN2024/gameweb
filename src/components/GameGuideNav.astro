---
interface Props {
  guides: { title: string; href: string }[];
  gameTitle: string;
}

const { guides, gameTitle } = Astro.props;
---

{
  guides.length > 0 && (
    <nav
      aria-label={`${gameTitle} guide navigation`}
      class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-5"
    >
      <p class="text-sm font-semibold text-white">All {gameTitle} guides</p>
      <ul class="mt-4 max-h-80 space-y-2 overflow-y-auto text-sm">
        {guides.map((guide) => (
          <li>
            <a
              href={guide.href}
              class="block text-[var(--color-text-muted)] transition hover:text-[var(--color-accent)]"
            >
              {guide.title}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
