---
import type { GameSlug } from '../consts';
import { getGameAccentGradient, getGameCoverUrl, getGameThumbFallback } from '../utils/images';

interface Props {
  slug: GameSlug;
  title: string;
  variant?: 'card' | 'hero' | 'thumb';
  class?: string;
}

const { slug, title, variant = 'card', class: className = '' } = Astro.props;

const src = getGameCoverUrl(slug, variant);
const fallback = getGameThumbFallback(slug);
const gradient = getGameAccentGradient(slug);

const aspectClass =
  variant === 'hero'
    ? 'aspect-[21/9] min-h-[12rem] sm:min-h-[16rem]'
    : variant === 'thumb'
      ? 'aspect-[16/10]'
      : 'aspect-[16/9]';
---

<div
  class:list={['relative overflow-hidden bg-[var(--color-surface-muted)]', aspectClass, className]}
  style={`background: ${gradient}`}
>
  <img
    src={src}
    alt={`${title} cover art`}
    class="absolute inset-0 h-full w-full object-cover object-center transition duration-500 group-hover:scale-105"
    loading={variant === 'hero' ? 'eager' : 'lazy'}
    decoding="async"
    width={616}
    height={353}
    data-fallback={fallback}
    onerror="this.onerror=null;this.src=this.dataset.fallback"
  />
  {
    variant === 'hero' && (
      <div
        class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[var(--color-surface)] via-[var(--color-surface)]/60 to-transparent"
        aria-hidden="true"
      />
    )
  }
</div>
