---
import type { GameSlug } from '../consts';
import { getGameAccentGradient, getGameCoverUrl } from '../utils/images';

interface Props {
  slug: GameSlug;
  title: string;
  variant?: 'card' | 'hero' | 'thumb';
  class?: string;
}

const { slug, title, variant = 'card', class: className = '' } = Astro.props;

const src = getGameCoverUrl(slug, variant === 'hero' ? 'hero' : 'card');
const gradient = getGameAccentGradient(slug);

const aspectClass =
  variant === 'hero'
    ? 'aspect-[21/9] min-h-[12rem] sm:min-h-[16rem]'
    : variant === 'thumb'
      ? 'aspect-[16/10]'
      : 'aspect-[16/9]';
---

<div
  class:list={['relative overflow-hidden bg-[var(--color-surface-muted)]', aspectClass, className]}
  style={`background: ${gradient}`}
>
  <img
    src={src}
    alt={`${title} cover art`}
    class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
    loading={variant === 'hero' ? 'eager' : 'lazy'}
    decoding="async"
    width={variant === 'thumb' ? 320 : 616}
    height={variant === 'thumb' ? 200 : 353}
  />
  <div
    class:list={[
      'pointer-events-none absolute inset-0',
      variant === 'hero'
        ? 'bg-gradient-to-t from-[var(--color-surface)] via-[var(--color-surface)]/60 to-transparent'
        : 'bg-gradient-to-t from-[var(--color-surface-elevated)]/90 via-transparent to-transparent',
    ]}
    aria-hidden="true"
  />
</div>
