---
import BaseLayout from '../layouts/BaseLayout.astro';
import GuideCard from '../components/GuideCard.astro';
import HeroHotGrid from '../components/HeroHotGrid.astro';
import { SITE } from '../consts';
import { getLatestGuides, getPublishedGuides, getHotGames, getTrendingGames, getPopularTags } from '../utils/guides';

const guides = await getPublishedGuides();
const latestGuides = await getLatestGuides(12);
const trendingGames = getTrendingGames();
const hotGames = getHotGames(6);
const popularTags = getPopularTags(guides, 10);

const hotGamesWithCounts = hotGames.map(({ slug, meta }) => ({
  slug,
  meta,
  guideCount: guides.filter((g) => g.data.game === slug).length,
}));
---

<BaseLayout>
  <section class="relative overflow-hidden border-b border-[var(--color-border)]">
    <div class="hero-mesh absolute inset-0" aria-hidden="true" />
    <div class="pointer-events-none absolute -right-32 top-0 h-96 w-96 rounded-full bg-[var(--color-accent)]/5 blur-3xl" aria-hidden="true" />

    <div class="relative mx-auto max-w-6xl px-4 py-12 lg:py-16">
      <div class="mx-auto max-w-3xl text-center">
        <p class="inline-flex items-center gap-2 rounded-full border border-[var(--color-accent)]/25 bg-[var(--color-accent)]/10 px-3 py-1 text-xs font-medium uppercase tracking-wider text-[var(--color-accent)]">
          Top 6 hottest on Steam
        </p>
        <h1 class="mt-5 text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-[3.25rem] lg:leading-tight">
          Guides for the games players are searching right now
        </h1>
        <p class="mt-4 text-base text-[var(--color-text-muted)] sm:text-lg">{SITE.description}</p>

        <div class="mt-6 flex flex-wrap items-center justify-center gap-3 text-sm">
          <span class="rounded-full border border-[var(--color-border)] bg-[var(--color-surface-elevated)]/80 px-3 py-1 text-[var(--color-text-muted)]">
            <span class="font-semibold text-white">{guides.length}</span> guides
          </span>
          <span class="rounded-full border border-[var(--color-border)] bg-[var(--color-surface-elevated)]/80 px-3 py-1 text-[var(--color-text-muted)]">
            <span class="font-semibold text-white">{trendingGames.length}</span> games
          </span>
        </div>

        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href="/guides/"
            class="rounded-lg bg-[var(--color-accent)] px-5 py-2.5 text-sm font-semibold text-[var(--color-surface)] transition hover:bg-[var(--color-accent-strong)]"
          >
            Browse all guides
          </a>
          <a
            href="/games/"
            class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-elevated)]/80 px-5 py-2.5 text-sm font-medium text-white transition hover:border-[var(--color-accent)]/40"
          >
            All games
          </a>
        </div>
      </div>

      <div class="mt-12 lg:mt-14">
        <div class="mb-5 flex items-end justify-between gap-4">
          <div>
            <h2 class="text-lg font-semibold text-white sm:text-xl">Hottest games</h2>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">
              Ranked by buzz — #{hotGamesWithCounts[0]?.meta.title} is #1 this week
            </p>
          </div>
          <a href="/games/" class="shrink-0 text-sm text-[var(--color-accent)] hover:underline">
            View all
          </a>
        </div>
        <HeroHotGrid games={hotGamesWithCounts} />
      </div>
    </div>
  </section>

  {
    popularTags.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 py-12">
        <h2 class="text-lg font-semibold text-white">Popular topics</h2>
        <p class="mt-1 text-sm text-[var(--color-text-muted)]">Quick search by what players look up most</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {popularTags.map((tag) => (
            <a
              href={`/search/?q=${encodeURIComponent(tag)}`}
              class="rounded-full border border-[var(--color-border)] bg-[var(--color-surface-elevated)] px-3 py-1.5 text-sm text-[var(--color-text-muted)] transition hover:border-[var(--color-accent)]/40 hover:text-white"
            >
              {tag}
            </a>
          ))}
        </div>
      </section>
    )
  }

  <section class="mx-auto max-w-6xl px-4 pb-16">
    <div class="flex items-end justify-between gap-4 border-t border-[var(--color-border)] pt-12">
      <div>
        <h2 class="text-2xl font-bold text-white">Latest guides</h2>
        <p class="mt-2 text-[var(--color-text-muted)]">
          New walkthroughs, builds, and buying advice across trending titles.
        </p>
      </div>
      <a href="/guides/" class="shrink-0 text-sm text-[var(--color-accent)] hover:underline">
        View all {guides.length}
      </a>
    </div>
    <div class="mt-8">
      <GuideCard guides={latestGuides} variant="list" />
    </div>
  </section>
</BaseLayout>
