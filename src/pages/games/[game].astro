---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuideCard from '../../components/GuideCard.astro';
import GameGuideNav from '../../components/GameGuideNav.astro';
import AffiliateCTA from '../../components/AffiliateCTA.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import HeroBanner from '../../components/HeroBanner.astro';
import { GAMES, type GameSlug } from '../../consts';
import { getGuidesByGame, getGuideUrl, formatDate } from '../../utils/guides';

export function getStaticPaths() {
  const gameSlugs = Object.keys(GAMES) as GameSlug[];

  return gameSlugs.map((game) => ({
    params: { game },
  }));
}

const { game } = Astro.params as { game: GameSlug };
const gameMeta = GAMES[game];
const guides = await getGuidesByGame(game);
const guideNav = guides.map((g) => ({
  title: g.data.title,
  href: getGuideUrl(g),
  date: formatDate(g.data.publishedAt),
}));
---

<BaseLayout
  title={`${gameMeta.title} Guides`}
  description={gameMeta.description}
  canonicalPath={`/games/${game}/`}
>
  <HeroBanner
    eyebrow={`Game hub · ${guides.length} guides`}
    title={`${gameMeta.title} Guides`}
    description={gameMeta.description}
    gameSlug={game}
    gameTitle={gameMeta.title}
  >
    <Breadcrumbs
      slot="breadcrumbs"
      items={[
        { label: 'Home', href: '/' },
        { label: 'Games', href: '/games/' },
        { label: gameMeta.title },
      ]}
    />
    <div class="flex flex-wrap gap-3">
      <a
        href="/guides/"
        class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)]/60 px-4 py-2 text-sm text-white backdrop-blur hover:border-[var(--color-accent)]/40"
      >
        Browse all guides
      </a>
      <a
        href={`/search/?q=${encodeURIComponent(gameMeta.title)}`}
        class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)]/60 px-4 py-2 text-sm text-white backdrop-blur hover:border-[var(--color-accent)]/40"
      >
        Search {gameMeta.title}
      </a>
    </div>
  </HeroBanner>

  <section class="mx-auto max-w-6xl px-4 py-14">
    <div class="grid gap-10 lg:grid-cols-[240px_minmax(0,1fr)]">
      <aside class="lg:sticky lg:top-24 lg:self-start">
        <GameGuideNav guides={guideNav} gameTitle={gameMeta.title} />
      </aside>

      <div>
        {
          guides.length > 0 ? (
            <GuideCard guides={guides} showGame={false} />
          ) : (
            <p class="text-[var(--color-text-muted)]">Guides coming soon.</p>
          )
        }

        <AffiliateCTA
          gameTitle={gameMeta.title}
          gameSlug={game}
          steamUrl={gameMeta.steamUrl}
          affiliateLabel={gameMeta.affiliateLabel}
        />
      </div>
    </div>
  </section>
</BaseLayout>
